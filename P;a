<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nova Browser Pro</title>
<style>
body { margin:0; font-family:Arial; background:#0f172a; color:white; }

#toolbar { display:flex; gap:8px; padding:10px; background:#1e293b; align-items:center; }
button { background:#334155; color:white; border:none; padding:6px 10px; border-radius:6px; cursor:pointer; }
button:hover { background:#475569; }
#url { flex:1; padding:6px; border-radius:6px; border:none; }

#tabs { display:flex; background:#020617; padding:5px; gap:5px; overflow-x:auto; }
.tab { padding:5px 10px; background:#1e293b; border-radius:6px; cursor:pointer; }
.active { background:#475569; }

iframe { width:100%; height:calc(100vh - 110px); border:none; }

#bookmarks { padding:5px; background:#020617; }

.light { background:white; color:black; }
.light #toolbar { background:#ddd; }
.light button { background:#ccc; color:black; }
.light #tabs { background:#eee; }
.light .tab { background:#ccc; }
</style>
</head>
<body>

<div id="tabs"></div>

<div id="toolbar">
  <button onclick="newTab()">＋</button>
  <button onclick="goBack()">⬅</button>
  <button onclick="goForward()">➡</button>
  <button onclick="refreshPage()">⟳</button>
  <input id="url" placeholder="Search or URL">
  <button onclick="navigate()">Go</button>
  <button onclick="toggleTheme()">🌙</button>
  <button onclick="addBookmark()">⭐</button>
</div>

<div id="bookmarks"></div>
<iframe id="view"></iframe>

<script>
let tabs = [];
let currentTab = 0;
let bookmarks = [];

function formatURL(input) {
  if (!input.startsWith("http")) return "https://www.google.com/search?q="+encodeURIComponent(input);
  return input;
}

function newTab(url="https://example.com") {
  tabs.push({history:[url], index:0});
  currentTab = tabs.length-1;
  renderTabs();
  loadURL(url);
}

function renderTabs() {
  const tabsDiv = document.getElementById("tabs");
  tabsDiv.innerHTML="";
  tabs.forEach((t,i)=>{
    const el = document.createElement("div");
    el.className = "tab"+(i===currentTab?" active":"");
    el.innerText = "Tab "+(i+1);
    el.onclick = ()=>{currentTab=i; loadURL(tabs[i].history[tabs[i].index]); renderTabs();};
    tabsDiv.appendChild(el);
  });
}

function loadURL(url) {
  document.getElementById("view").src=url;
  document.getElementById("url").value=url;
}

function navigate() {
  const input = document.getElementById("url").value;
  const url = formatURL(input);
  let tab = tabs[currentTab];
  tab.history = tab.history.slice(0, tab.index+1);
  tab.history.push(url);
  tab.index++;
  loadURL(url);
}

function goBack() {
  let tab = tabs[currentTab];
  if (tab.index>0) { tab.index--; loadURL(tab.history[tab.index]); }
}

function goForward() {
  let tab = tabs[currentTab];
  if (tab.index<tab.history.length-1) { tab.index++; loadURL(tab.history[tab.index]); }
}

function refreshPage() { loadURL(tabs[currentTab].history[tabs[currentTab].index]); }

function toggleTheme() {
  document.body.classList.toggle("light");
}

function addBookmark() {
  const url = tabs[currentTab].history[tabs[currentTab].index];
  bookmarks.push(url);
  renderBookmarks();
}

function renderBookmarks() {
  const div = document.getElementById("bookmarks");
  div.innerHTML = "";
  bookmarks.forEach(b=>{
    const btn = document.createElement("button");
    btn.innerText = b;
    btn.onclick = ()=>loadURL(b);
    div.appendChild(btn);
  });
}

window.addEventListener("keydown", e=>{ if(e.key==="Enter") navigate(); });

// Init
newTab();
</script>

</body>
</html>
